# ============================================================================
#  /opt/hookline/.env  —  copy to /opt/hookline/.env on the server, fill in,
#  keep OFF git. Consumed by deploy/docker-compose.prod.yml.
#  ASP.NET maps "__" to nested config keys (Foo__Bar -> Foo:Bar).
#
#  The placeholders below intentionally contain "change-me" / "CHANGE-ME": the
#  backend's GuardSecurityConfig REFUSES TO BOOT in Production if any GUARDED secret
#  is empty or contains "change-me" (case-insensitive) or equals "dev-admin-token".
#  Guarded = the three core auth primitives (TokenEncryption__Key, Identity__SigningKey,
#  BackendAuth__AdminToken) PLUS each module's Slack signing secret
#  (YouTubeUploads__Slack__SigningSecret, YouTubeComments__Slack__SigningSecret) — an empty
#  signing secret would 401 every "Reject on YouTube" interactivity press invisibly.
#  So a copied-but-unfilled .env fails fast (exit 1) instead of booting broken. Generate the
#  core values with `openssl rand -base64 36`; the signing secrets come from each Slack app.
# ============================================================================

# ---- GHCR image coordinates (lowercase). IMAGE_TAG is overwritten per release
#      by the deploy workflow (commit SHA); "latest" is the manual fallback. -----
GH_REPO=skyp1nus/hookline
IMAGE_TAG=latest

# ---- Public origin. The shared Caddy terminates TLS for this domain. ----------
#      Drives BOTH modules' PublicBaseUrl + every OAuth RedirectUri + the panel
#      origin + NEXT_PUBLIC_BACKEND_URL (compose interpolation only).
App__PublicBaseUrl=https://danielhub.dev

# ---- Postgres (SHARED instance, database "hookline", role "hookline") ----------
#      Host "postgres" is the shared stack's network alias on the "web" network.
#      Password MUST equal HOOKLINE_DB_PASSWORD in /opt/shared/.env.
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=hookline;Username=hookline;Password=CHANGE-ME-hookline-db-password

# ---- Redis (SHARED instance) --------------------------------------------------
ConnectionStrings__Redis=redis:6379

# ---- Secret-at-rest master key (AES-256-GCM) ----------------------------------
#      NEVER change after first deploy — rotating it makes every stored Google
#      refresh token / Slack secret / YouTube key undecryptable.  openssl rand -base64 48
TokenEncryption__Key=CHANGE-ME-aes-master-key-openssl-rand-base64-48

# ---- HMAC key for the BFF -> backend identity assertion -----------------------
#      MUST be byte-identical to the frontend's IDENTITY_SIGNING_KEY (wired from
#      this same var in compose).  openssl rand -base64 36
Identity__SigningKey=CHANGE-ME-identity-signing-key-openssl-rand-base64-36

# ---- Admin token proving the BFF is the caller (X-Admin-Token) -----------------
#      MUST equal the frontend's BACKEND_ADMIN_TOKEN (wired from this var).  openssl rand -base64 36
BackendAuth__AdminToken=CHANGE-ME-admin-token-openssl-rand-base64-36

# ---- Next.js BFF session-cookie HMAC key --------------------------------------
#      openssl rand -base64 36
SESSION_SECRET=CHANGE-ME-session-secret-openssl-rand-base64-36

# ---- First-run bootstrap admin (seeded only when auth.users is empty) ----------
#      Log in as this, then do the one-time Create-Owner in the panel. A BLANK
#      password generates a break-glass password logged ONCE at startup (Warning) —
#      set an explicit strong one for prod so you control it.
Bootstrap__AdminEmail=admin@hookline.local
Bootstrap__AdminPassword=CHANGE-ME-strong-bootstrap-password

# ---- YouTube Uploads module — Slack app (signing secret is env-only) ----------
#      RedirectUri is composed in compose as ${App__PublicBaseUrl}/slack/youtube-uploads/oauth/callback
YouTubeUploads__Slack__SigningSecret=CHANGE-ME
YouTubeUploads__Slack__ClientId=CHANGE-ME
YouTubeUploads__Slack__ClientSecret=CHANGE-ME

# ---- YouTube Uploads module — Google OAuth seed (optional "Default (env)" project)
#      RedirectUri is composed as ${App__PublicBaseUrl}/google/youtube-uploads/oauth/callback
#      Per-project Google clients are added in-app; this seed is optional.
YouTubeUploads__Google__SeedClientId=CHANGE-ME.apps.googleusercontent.com
YouTubeUploads__Google__SeedClientSecret=CHANGE-ME

# ---- YouTube Comments module — Slack app ---------------------------------------
#      RedirectUri is composed as ${App__PublicBaseUrl}/slack/youtube-comments/oauth/callback
#      (Comments has NO Google OAuth — YouTube polling uses API keys entered in-app.)
#      SigningSecret verifies the "Reject on YouTube" interactivity callback; the backend
#      REFUSES TO BOOT in Production if it is empty or a placeholder (GuardSecurityConfig),
#      so a forgotten interactivity secret can never silently 401 every button press.
YouTubeComments__Slack__SigningSecret=CHANGE-ME
YouTubeComments__Slack__ClientId=CHANGE-ME
YouTubeComments__Slack__ClientSecret=CHANGE-ME

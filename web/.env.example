# ── Hookline web (Next BFF) ───────────────────────────────────────────────
# Server-only: where the BFF proxy forwards to (never shipped to the browser).
BACKEND_URL=http://localhost:8080
# Server-only: shared admin token the BFF attaches to every backend call.
BACKEND_ADMIN_TOKEN=dev-admin-token
# Server-only: HMAC key used to sign the BFF session cookie + the user identity
# assertion forwarded to the backend. Use a long random string in prod.
SESSION_SECRET=dev-session-secret-change-me

# Client-visible: backend origin used for OAuth "Connect" redirects.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Set true behind HTTPS (prod). Must be false on plain http://localhost.
COOKIE_SECURE=false

# Local fast-dev escape hatch: skip auth entirely (no login wall).
NEXT_PUBLIC_NO_AUTH=true

# ── Hookline local stack (docker compose) ─────────────────────────────────
# Copy to .env and fill real secrets for anything beyond local dev.

# Postgres role password (shared by the DB + the backend connection string).
POSTGRES_PASSWORD=hookline

# Backend secrets. Generate strong values for prod: openssl rand -base64 36
TOKEN_ENCRYPTION_KEY=dev-token-encryption-key-change-me   # AES master key — NEVER change after launch
IDENTITY_SIGNING_KEY=dev-identity-signing-key-change-me   # HMAC key for the BFF→backend identity assertion
BACKEND_ADMIN_TOKEN=dev-admin-token                       # proves the BFF is calling (X-Admin-Token)
SESSION_SECRET=dev-session-secret-change-me               # signs the BFF session cookie

# Fast-dev: backend runs as a dev admin without the BFF token/identity. Development-only —
# it is forced off and refused at boot in Production. Flip to true locally to skip auth.
AUTH_DEV_NO_AUTH=false
NEXT_PUBLIC_NO_AUTH=false

# First-run bootstrap admin (seeded only when the users table is empty).
BOOTSTRAP_ADMIN_EMAIL=admin@hookline.local
BOOTSTRAP_ADMIN_PASSWORD=

# Client-visible backend origin for OAuth "Connect" redirects (build-arg inlined).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# ── Stable dev tunnel (OPTIONAL) ───────────────────────────────────────────────────────────────────
# A public HTTPS host that forwards to the backend on :8080, used for provider callbacks that must be
# internet-reachable (Google OAuth, Slack OAuth install, and the canonical HTTP webhook path). Every
# redirect/webhook env var below derives from it: ${TUNNEL_URL:-http://localhost:8080}/<path>. The value
# MUST EXACTLY match every redirect/webhook URI registered in Google + both Slack apps. Leave it UNSET to
# derive everything from http://localhost:8080 — fine for Google OAuth on localhost and for Slack Socket
# Mode (below), which needs no public URL at all. See docs/dev/local-testing.md.
#TUNNEL_URL=https://hookline-dev.danielhub.dev

# ── Slack apps — TWO apps, one PER MODULE (YouTube Uploads + YouTube Comments) ──────────────────────
# From each Slack app: Basic Information → Signing Secret; OAuth & Permissions → Client ID / Client Secret.
#SLACK_SIGNING_SECRET=                  # YouTube Uploads app
#SLACK_CLIENT_ID=
#SLACK_CLIENT_SECRET=
#SLACK_COMMENTS_SIGNING_SECRET=         # YouTube Comments app
#SLACK_COMMENTS_CLIENT_ID=
#SLACK_COMMENTS_CLIENT_SECRET=

# ── Google OAuth client (YouTube Uploads only — Comments polls via API keys, no Google OAuth) ───────
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# ── Dev-only Slack Socket Mode (NO tunnel needed for INBOUND Slack) ─────────────────────────────────
# Opens a WebSocket to Slack so inbound events (Uploads) and the "Reject on YouTube" button (Comments)
# reach the backend without any public Request URL. OFF by default; the backend REFUSES to boot with
# these true in Production. Per module (separate apps, no cross-module dispatcher). For each app:
# Basic Information → App-Level Tokens → generate a token (xapp-…) with the connections:write scope.
#UPLOADS_SLACK_SOCKET_MODE=true
#UPLOADS_SLACK_APP_TOKEN=xapp-1-...
#COMMENTS_SLACK_SOCKET_MODE=true
#COMMENTS_SLACK_APP_TOKEN=xapp-1-...
